<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Medicines</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header>
        <h1>Medicines</h1>
        <nav>
            <a href="/">Home</a>
            <a href="/categories">Categories</a>
            <a href="/medicines">Medicines</a>
            <a href="/manufacturers">Manufacturers</a>
        </nav>
    </header>

    <main>
        <div class="page">
            <div class="content">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Expires</th>
                            <th>Category</th>
                            <th>Manufacturer</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% medicines.forEach(med=> {
                            const category = categories.find(c=> c.id === med.category_id);
                            const manufacturer = manufacturers.find(m=> m.id === med.manufacturer_id);
                        %>
                            <tr>
                                <td><%= med.name %></td>
                                <td><%= med.description %></td>
                                <td>$<%= med.price %></td>
                                <td><%= med.stock_quantity %></td>
                                <td><%= med.expiration_date.toISOString().split("T")[0] %></td>
                                <td><%= category ? category.name : "Unknown" %></td>
                                <td><%= manufacturer ? manufacturer.name : "Unknown" %></td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>

            <div class="form-panel">
                <h2>Add new medicine</h2>
                <form method="post" action="/medicines">
                    <div>
                        <label for="name">Name</label>
                        <input type="text" id="name" name="name">
                    </div>

                    <div>
                        <label for="description">Description</label>
                        <input type="text" id="description" name="description">
                    </div>

                    <div>
                        <label for="price">Price</label>
                       <input type="text" inputmode="decimal" pattern="^\d+(\.\d{1,2})?$" id="price" name="price">

                    </div>

                    <div>
                        <label for="stock_quantity">Stock quantity</label>
                        <input type="number" id="stock_quantity" name="stock_quantity">
                    </div>

                    <div>
                        <label for="expiration_date">Expiration date</label>
                        <input type="date" id="expiration_date" name="expiration_date">
                    </div>

                    <div>
                        <label for="category_id">Category</label>
                        <select id="category_id" name="category_id">
                            <% categories.forEach(category=> { %>
                                <option value="<%= category.id %>"><%= category.name %></option>
                                <% }) %>
                        </select>
                    </div>

                    <div>
                        <label for="manufacturer_id">Manufacturer</label>
                        <select id="manufacturer_id" name="manufacturer_id">
                            <% manufacturers.forEach(manufacturer=> { %>
                                <option value="<%= manufacturer.id %>"><%= manufacturer.name %></option>
                                <% }) %>
                        </select>
                    </div>

                    <button type="submit">Add</button>
                </form>
            </div>
        </div>
    </main>
</body>

</html>
